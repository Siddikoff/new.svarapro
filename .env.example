# Root .env consumed by docker-compose.yml.
# Copy to `.env` and fill in real values before running `docker compose up -d`.
# Per-service runtime config for the NestJS server lives in `server/.env`.

# ---------------------------------------------------------------------------
# Image pins (kept here so the same versions are reproduced on every machine)
# ---------------------------------------------------------------------------
NODE_IMAGE=node:20.17.0-alpine
NGINX_IMAGE=nginx:1.27-alpine
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# ---------------------------------------------------------------------------
# Public URLs (used by the client bundle at build time and by CORS)
# ---------------------------------------------------------------------------
# Browser-visible app origin (must match nginx server_name + Let's Encrypt cert).
APP_URL=https://app.svarapro.com
VITE_APP_URL=https://app.svarapro.com
VITE_WS_URL=wss://app.svarapro.com
VITE_API_URL=https://app.svarapro.com/api/v1

# Backend's idea of itself (used to render Telegram callbacks, etc.).
API_BASE_URL=https://app.svarapro.com

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=svarapro
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=svarapro

# ---------------------------------------------------------------------------
# Telegram bots
# ---------------------------------------------------------------------------
# Main bot (opens the Mini App / handles auth).
BOT_TOKEN=
# Service bot (admin notifications, withdraw approvals).
SERVICE_BOT_TOKEN=
# Comma-separated Telegram user_ids that have admin access in the service bot.
ADMIN_IDS=

# Shared secret between the bots and the backend (used by the service bot to
# call back into /api/v1/* admin endpoints).
API_SECRET=change_me_long_random_string

# ---------------------------------------------------------------------------
# Payments (NirvanaPay / NOROS) — optional, leave empty to disable deposits
# ---------------------------------------------------------------------------
NIRVANAPAY_API_PUBLIC_TJK=
NIRVANAPAY_API_PRIVATE_TJK=
