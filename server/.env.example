# Noros API Configuration
# Each currency might have separate API keys from Noros dashboard
NOROS_BASE_URL=https://rest.noros.org/api/v1

# RUB (Russian Ruble) - Multiple payment channels with different limits and fees
# P2P RUB classic (5000-100000 RUB, fee 15%)
NOROS_API_KEY_RUB_CLASSIC=your_noros_api_key_rub_classic_here
NOROS_API_SECRET_KEY_RUB_CLASSIC=your_noros_api_secret_key_rub_classic_here

# P2P RUB 1-5k (1000-4999 RUB, fee 16%)
NOROS_API_KEY_RUB_1_5K=your_noros_api_key_rub_1_5k_here
NOROS_API_SECRET_KEY_RUB_1_5K=your_noros_api_secret_key_rub_1_5k_here

# P2P RUB Alfa-Alfa (1000-100000 RUB, fee 12%, internal bank transfers)
NOROS_API_KEY_RUB_ALFA=your_noros_api_key_rub_alfa_here
NOROS_API_SECRET_KEY_RUB_ALFA=your_noros_api_secret_key_rub_alfa_here

# UZS (Uzbek Som)
NOROS_API_KEY_UZS=your_noros_api_key_uzs_here
NOROS_API_SECRET_KEY_UZS=your_noros_api_secret_key_uzs_here

# KZT (Kazakh Tenge)
NOROS_API_KEY_KZT=your_noros_api_key_kzt_here
NOROS_API_SECRET_KEY_KZT=your_noros_api_secret_key_kzt_here

# KGS (Kyrgyz Som)
NOROS_API_KEY_KGS=your_noros_api_key_kgs_here
NOROS_API_SECRET_KEY_KGS=your_noros_api_secret_key_kgs_here

# Alfabit API Configuration (existing crypto payment provider)
ALFABIT_API_KEY=your_alfabit_api_key_here
ALFABIT_BASE_URL=https://pay.alfabit.org

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=svarapro

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Application Configuration
NODE_ENV=development
PORT=3000
