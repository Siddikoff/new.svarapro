# Base URL of the Svara REST API (NestJS).
# Leave empty in environments where the bundle is served behind a proxy
# (e.g. nginx mapping /api/* to the backend) — `api/client.ts` then issues
# relative requests like `fetch('/rooms')`.
VITE_API_BASE_URL=

# Socket.IO endpoint exposed by the server's `RoomsGateway` / `GameGateway`.
# Leave empty to disable the live room feed; the lobby will keep working on
# REST polling only.
VITE_SOCKET_URL=
